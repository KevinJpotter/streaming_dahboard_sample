{
  "pages": [
    {
      "name": "stream_overview",
      "displayName": "Stream Overview",
      "layout": [
        {
          "widget": {
            "name": "stream_status_table",
            "queries": [
              {
                "name": "stream_overview_query",
                "query": {
                  "datasetName": "ds_stream_overview"
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {
                    "fieldName": "query_name",
                    "displayName": "Stream",
                    "type": "string"
                  },
                  {
                    "fieldName": "stream_status",
                    "displayName": "Status",
                    "type": "string"
                  },
                  {
                    "fieldName": "last_batch_ts",
                    "displayName": "Last Batch",
                    "type": "datetime"
                  },
                  {
                    "fieldName": "uptime_hours",
                    "displayName": "Uptime (hrs)",
                    "type": "number"
                  },
                  {
                    "fieldName": "sla_breach_count",
                    "displayName": "SLA Breaches",
                    "type": "number"
                  },
                  {
                    "fieldName": "last_error_ts",
                    "displayName": "Last Error",
                    "type": "datetime"
                  }
                ]
              },
              "conditionalFormatting": [
                {
                  "column": "stream_status",
                  "rules": [
                    {
                      "condition": {
                        "operator": "EQUAL",
                        "operand": "ACTIVE"
                      },
                      "color": "green"
                    },
                    {
                      "condition": {
                        "operator": "EQUAL",
                        "operand": "INACTIVE"
                      },
                      "color": "yellow"
                    },
                    {
                      "condition": {
                        "operator": "EQUAL",
                        "operand": "ERROR"
                      },
                      "color": "red"
                    }
                  ]
                }
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 4
          }
        },
        {
          "widget": {
            "name": "active_streams_counter",
            "queries": [
              {
                "name": "active_count_query",
                "query": {
                  "datasetName": "ds_stream_overview"
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "query_name",
                  "displayName": "Active Streams",
                  "type": "quantitative",
                  "aggregateType": "COUNT"
                }
              },
              "filter": {
                "fieldName": "stream_status",
                "values": [
                  "ACTIVE"
                ]
              }
            }
          },
          "position": {
            "x": 0,
            "y": 4,
            "width": 2,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "sla_breach_counter",
